---
import BaseLayout from "./BaseLayout.astro";
import Sidebar from "../components/docs/Sidebar.astro";
import Toc from "../components/docs/Toc.astro";
import Breadcrumbs from "../components/docs/Breadcrumbs.astro";
import Watermark from "../components/docs/Watermark.astro";
import type { MarkdownHeading } from "astro";

interface Props {
  title: string;
  description?: string;
  section: "api" | "guide" | "cookbook";
  currentSlug: string;
  breadcrumbTitle: string;
  watermarkChar: string;
  headings: MarkdownHeading[];
}
const {
  title,
  description,
  section,
  currentSlug,
  breadcrumbTitle,
  watermarkChar,
  headings,
} = Astro.props;
---
<BaseLayout title={`${title} · snitchbot docs`} description={description}>
  <button
    class="drawer-btn"
    type="button"
    aria-label="Open navigation"
    aria-expanded="false"
    data-drawer-toggle
  >
    <span></span><span></span><span></span>
  </button>

  <div class="scrim" data-drawer-scrim></div>

  <div class="docs">
    <div class="docs__sb" data-drawer>
      <Sidebar currentSlug={currentSlug} />
    </div>

    <main class="reading">
      <article class="reading__inner">
        <Watermark char={watermarkChar} />
        <Breadcrumbs section={section} title={breadcrumbTitle} />
        <slot />
      </article>
    </main>

    <div class="docs__toc">
      <Toc headings={headings} />
    </div>
  </div>

  <script>
    import { initDrawer } from "../components/docs/drawer";
    initDrawer();

    // Wrap each Shiki <pre> with a header (language label + copy button).
    const LANG_LABEL: Record<string, string> = {
      python: "Python",
      bash: "Shell",
      shell: "Shell",
      sh: "Shell",
      ts: "TypeScript",
      typescript: "TypeScript",
      js: "JavaScript",
      javascript: "JavaScript",
      json: "JSON",
      yaml: "YAML",
      yml: "YAML",
      toml: "TOML",
      text: "Text",
      plaintext: "Text",
    };

    document.querySelectorAll<HTMLPreElement>(".reading__inner pre.astro-code").forEach((pre) => {
      if (pre.parentElement?.classList.contains("code-wrap")) return;

      const lang = pre.dataset.language ?? "text";
      const label = LANG_LABEL[lang] ?? lang;

      const wrap = document.createElement("div");
      wrap.className = "code-wrap";

      const head = document.createElement("div");
      head.className = "code-wrap__head";

      const langSpan = document.createElement("span");
      langSpan.className = "code-wrap__lang";
      langSpan.textContent = label;

      const copyBtn = document.createElement("button");
      copyBtn.type = "button";
      copyBtn.className = "code-wrap__copy";
      copyBtn.textContent = "Copy";
      copyBtn.setAttribute("aria-label", "Copy code to clipboard");

      copyBtn.addEventListener("click", async () => {
        const code = pre.querySelector("code")?.innerText ?? pre.innerText;
        try {
          await navigator.clipboard.writeText(code);
          copyBtn.textContent = "Copied";
          copyBtn.classList.add("is-copied");
          setTimeout(() => {
            copyBtn.textContent = "Copy";
            copyBtn.classList.remove("is-copied");
          }, 1600);
        } catch {
          copyBtn.textContent = "Failed";
          setTimeout(() => (copyBtn.textContent = "Copy"), 1600);
        }
      });

      head.append(langSpan, copyBtn);

      pre.parentElement?.insertBefore(wrap, pre);
      wrap.append(head, pre);
    });
  </script>
</BaseLayout>

<style>
  .docs {
    display: grid;
    grid-template-columns: var(--docs-sidebar-w) 1fr var(--docs-toc-w);
    min-height: 100vh;
  }
  .docs__sb { position: sticky; top: 0; max-height: 100vh; overflow-y: auto; }

  .reading {
    position: relative;
    background: var(--color-reading-bg);
    min-height: 100vh;
  }
  .reading__inner {
    position: relative;
    padding: 3.2rem 3.2rem 5rem;
    max-width: calc(var(--docs-reading-max) + 4rem);
    margin: 0 auto;
    color: var(--color-sumi);
    font-family: var(--font-body);
    font-size: 15.5px;
    line-height: 1.7;
  }
  .reading__inner :global(h2) {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 28px;
    color: var(--color-sumi);
    margin: 2.2rem 0 0.8rem;
    scroll-margin-top: 1.5rem;
  }
  .reading__inner :global(h3) {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 20px;
    color: var(--color-sumi);
    margin: 1.4rem 0 0.5rem;
    scroll-margin-top: 1.5rem;
  }
  .reading__inner :global(p)  { margin: 0.8rem 0; }
  .reading__inner :global(a)  { color: var(--color-accent); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 2px; }
  .reading__inner :global(ul),
  .reading__inner :global(ol) { margin: 0.8rem 0; padding-left: 1.4rem; }
  .reading__inner :global(li) { margin: 0.2rem 0; }
  .reading__inner :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    background: rgba(181, 75, 60, 0.05);
    padding: 0.6rem 0.9rem;
    margin: 1rem 0;
    color: var(--color-sumi-soft);
    font-style: italic;
  }
  .reading__inner :global(code) {
    font-family: var(--font-mono);
    font-size: 13px;
    background: rgba(30, 26, 21, 0.06);
    padding: 1px 5px;
    border-radius: 3px;
  }
  .reading__inner :global(hr) {
    border: none;
    border-top: 1px solid rgba(138, 122, 95, 0.25);
    margin: 2rem 0;
  }

  /* Markdown code blocks (Shiki output) */
  .reading__inner :global(.code-wrap) {
    position: relative;
    margin: 1.4rem 0;
    border-radius: 10px;
    overflow: hidden;
    background: #24292e;
    box-shadow:
      0 4px 16px rgba(30, 26, 21, 0.10),
      0 18px 32px rgba(30, 26, 21, 0.06);
  }
  .reading__inner :global(.code-wrap__head) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px 8px 14px;
    background: #1f2429;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #8a99a8;
  }
  .reading__inner :global(.code-wrap__lang) {
    font-weight: 600;
  }
  .reading__inner :global(.code-wrap__copy) {
    appearance: none;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: #c8d0d8;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    padding: 3px 9px;
    border-radius: 5px;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .reading__inner :global(.code-wrap__copy:hover) {
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.22);
  }
  .reading__inner :global(.code-wrap__copy.is-copied) {
    color: #28c840;
    border-color: rgba(40, 200, 64, 0.4);
  }
  .reading__inner :global(.code-wrap > pre.astro-code) {
    margin: 0;
    border-radius: 0;
    padding: 14px 16px;
    font-size: 12.5px;
    line-height: 1.7;
  }
  .reading__inner :global(pre.astro-code code) {
    background: transparent;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .drawer-btn {
    display: none;
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 50;
    width: 40px;
    height: 40px;
    background: var(--color-paper);
    border: 1px solid rgba(138, 122, 95, 0.4);
    border-radius: 6px;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 4px;
    padding: 10px 8px;
  }
  .drawer-btn span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-sumi);
    border-radius: 1px;
  }

  .scrim {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(30, 26, 21, 0.45);
    z-index: 40;
  }
  .scrim.open { display: block; }

  @media (max-width: 1100px) {
    .docs { grid-template-columns: var(--docs-sidebar-w) 1fr; }
    .docs__toc { display: none; }
  }
  @media (max-width: 900px) {
    .docs { grid-template-columns: 1fr; }
    .docs__sb {
      position: fixed;
      inset: 0 auto 0 0;
      width: var(--docs-sidebar-w);
      transform: translateX(-100%);
      transition: transform 0.25s ease;
      z-index: 45;
      box-shadow: 2px 0 20px rgba(30, 26, 21, 0.2);
    }
    .docs__sb.open { transform: translateX(0); }
    .drawer-btn { display: flex; }
    .reading__inner { padding: 3rem 1.3rem 4rem; }
  }
</style>
