---
import type { MarkdownHeading } from "astro";

interface Props {
  headings: MarkdownHeading[];
}
const { headings } = Astro.props;
const items = headings.filter(h => h.depth === 2 || h.depth === 3);
---
<aside class="toc" aria-labelledby="toc-head">
  <h4 class="toc__head" id="toc-head">On this page</h4>
  <ol>
    {items.map(h => (
      <li class:list={[`toc__l${h.depth}`]}>
        <a href={`#${h.slug}`} data-toc-link={h.slug}>{h.text}</a>
      </li>
    ))}
  </ol>
</aside>

<script>
  import { initToc } from "./toc";
  initToc();
</script>

<style>
  .toc {
    width: var(--docs-toc-w);
    padding: 1.8rem 0.8rem 2rem;
    font-size: 12.5px;
    line-height: 1.55;
    position: sticky;
    top: 2rem;
    align-self: flex-start;
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
  }
  .toc__head {
    font-family: var(--font-mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-ink-faded);
    margin: 0 0 0.6rem;
    padding-left: 0.8rem;
  }
  .toc ol { list-style: none; padding: 0; margin: 0; }
  .toc li { margin: 0; padding: 2px 0; }
  .toc__l3 { padding-left: 0.9rem; font-size: 12px; }
  .toc a {
    display: block;
    padding: 2px 0.8rem;
    color: var(--color-ink-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
  }
  .toc a:hover { color: var(--color-accent); }
  .toc a.active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
  }
  @media (max-width: 1100px) { .toc { display: none; } }
</style>
