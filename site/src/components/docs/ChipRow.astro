---
interface Props {
  chips: string[];
}
const { chips } = Astro.props;
---
<ul class="chips">
  {chips.map(c => <li class="chip">{c}</li>)}
</ul>

<style>
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.8rem 0 1.4rem;
    padding: 0;
    list-style: none;
  }
  .chip {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border: 1px solid var(--color-ink-faded);
    border-radius: 999px;
    color: var(--color-ink-muted);
    background: transparent;
  }
</style>
