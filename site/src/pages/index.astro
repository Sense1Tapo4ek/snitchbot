---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/hero/Hero.astro";
import Cases from "../components/cases/Cases.astro";
import Metrics from "../components/metrics/Metrics.astro";
import Architecture from "../components/architecture/Architecture.astro";
import Install from "../components/install/Install.astro";
import Footer from "../components/footer/Footer.astro";
---
<BaseLayout>
  <main class="mx-auto max-w-[1600px] px-4 md:px-6 py-10 flex flex-col gap-12">
    <Hero />
    <Cases />
    <Metrics />
    <Architecture />
    <Install />
    <Footer />
  </main>
</BaseLayout>
