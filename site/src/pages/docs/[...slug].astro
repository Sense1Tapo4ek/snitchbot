---
import { getCollection, type CollectionEntry } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";
import CodeBlock from "../../components/docs/CodeBlock.astro";
import Callout from "../../components/docs/Callout.astro";
import ChipRow from "../../components/docs/ChipRow.astro";
import ExamplePair from "../../components/docs/ExamplePair.astro";
import ParamsTable from "../../components/docs/ParamsTable.astro";
import Step from "../../components/docs/Step.astro";
import TgAlert from "../../components/docs/TgAlert.astro";
import Troubleshooting from "../../components/docs/Troubleshooting.astro";
import TryIt from "../../components/docs/TryIt.astro";
import WhatsNext from "../../components/docs/WhatsNext.astro";

export async function getStaticPaths() {
  const entries = await getCollection("docs");
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"docs">;
}
const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const components = {
  CodeBlock,
  Callout,
  ChipRow,
  ExamplePair,
  ParamsTable,
  Step,
  TgAlert,
  Troubleshooting,
  TryIt,
  WhatsNext,
};
---
<DocsLayout
  title={entry.data.title}
  description={entry.data.summary}
  section={entry.data.section}
  currentSlug={entry.slug}
  breadcrumbTitle={entry.data.title}
  watermarkChar={entry.data.watermark}
  headings={headings}
>
  <Content components={components} />
</DocsLayout>
